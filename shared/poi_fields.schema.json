{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nearbynearby.com/schemas/poi_fields.schema.json",
  "title": "POI Field Registry",
  "description": "Meta-schema constraining each entry in shared/poi_fields.json — the single source of truth describing every POI field. Generated by scripts/gen_poi_registry.py.",
  "type": "array",
  "items": { "$ref": "#/$defs/field" },
  "$defs": {
    "poiType": {
      "type": "string",
      "enum": [
        "BUSINESS",
        "SERVICES",
        "PARK",
        "TRAIL",
        "EVENT",
        "YOUTH_ACTIVITIES",
        "JOBS",
        "VOLUNTEER_OPPORTUNITIES",
        "DISASTER_HUBS"
      ]
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "label",
        "type",
        "group",
        "order",
        "applies_to",
        "tier",
        "audience",
        "render",
        "icon",
        "value_source",
        "schema_org",
        "source",
        "computed",
        "card",
        "deprecated",
        "replaced_by"
      ],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "boolean",
            "enum",
            "multi",
            "text",
            "richtext",
            "url",
            "phone",
            "email",
            "money",
            "number",
            "date",
            "datetime",
            "geo",
            "image",
            "image[]",
            "relation",
            "list",
            "dict"
          ]
        },
        "group": {
          "type": "string",
          "minLength": 1
        },
        "order": {
          "type": "integer"
        },
        "applies_to": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/poiType" }
        },
        "tier": {
          "type": "string",
          "enum": ["free", "paid", "any"]
        },
        "audience": {
          "type": "string",
          "enum": ["public", "admin", "partner"]
        },
        "render": {
          "type": "string",
          "enum": ["auto", "bespoke", "hidden"]
        },
        "icon": {
          "type": ["string", "null"]
        },
        "value_source": {
          "type": ["string", "null"]
        },
        "schema_org": {
          "type": ["string", "null"]
        },
        "source": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(poi|business|park|trail|event)\\.[a-z0-9_]+$|^computed\\.[a-z0-9_]+$|^images:[a-z0-9_]+$"
        },
        "computed": {
          "type": "boolean"
        },
        "card": {
          "type": "boolean"
        },
        "deprecated": {
          "type": "boolean"
        },
        "replaced_by": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
